# ── LLM Configuration ────────────────────────────────────────────────────────
# Provider: "openai" (default) | "ollama" (local)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
# For Qwen via DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# For local Ollama: http://localhost:11434/v1
LLM_MODEL=gpt-4o
# Alternative: Qwen2.5-Coder-32B-Instruct

# ── Ollama local model (alternative) ──────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3-vl:8b
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama

# ── Redis (for Celery task queue) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage paths ─────────────────────────────────────────────────────────────
# Where input/output data files are stored
DATA_ROOT=/data
BENCHMARK_DIR=./benchmarks

# ── Sandbox configuration ─────────────────────────────────────────────────────
# local: runs in subprocess (dev/test)
# docker: runs in Docker container (production)
SANDBOX_MODE=local
SANDBOX_IMAGE=dataflow-sandbox:latest
SANDBOX_MEMORY_MB=2048
SANDBOX_CPU_QUOTA=0.5
SANDBOX_TIMEOUT_SECONDS=300

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=dataflow-agent
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | console

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
